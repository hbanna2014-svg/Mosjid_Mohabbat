rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - email: string (required)
    //   - role: string (required, ['admin', 'authority', 'user'])
    //   - mosqueId: string (optional)
    //
    // Collection: mosques
    // Document ID: {mosqueId}
    // Fields:
    //   - name: string (required)
    //   - adminUid: string (required) - UID of the authority
    //   - active: bool (required)
    //   - prayerTimes: list of maps (required)
    //   - jummahTime: string (optional)
    //   - khateeb: string (optional)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "hasanul.banna1991@gmail.com" && request.auth.token.email_verified == true));
    }

    function isMosqueAuthority(mosqueId) {
      return isAuthenticated() && 
        (resource.data.adminUid == request.auth.uid || isAdmin());
    }

    // Domain Validators
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string &&
             data.role in ['admin', 'authority', 'user'] &&
             data.keys().hasOnly(['email', 'role', 'mosqueId']);
    }

    function isValidMosque(data) {
      return data.keys().hasAll(['name', 'adminUid', 'active', 'prayerTimes']) &&
             data.name is string && data.name.size() < 100 &&
             data.adminUid is string &&
             data.active is bool &&
             data.prayerTimes is list &&
             (!('jummahTime' in data) || data.jummahTime == null || data.jummahTime is string) &&
             (!('khateeb' in data) || data.khateeb == null || data.khateeb is string) &&
             data.keys().hasOnly(['name', 'address', 'location', 'active', 'adminUid', 'prayerTimes', 'jummahTime', 'khateeb']);
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
    }

    match /mosques/{mosqueId} {
      allow read: if true; // Public can read mosque times
      allow create: if isAdmin(); // Only super admin can add new mosques
      allow update: if isMosqueAuthority(mosqueId) && isValidMosque(request.resource.data);
      allow delete: if isAdmin();
    }

    match /masayel/{masalaId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
